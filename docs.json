{
  "site": {
    "name": "crucible",
    "description": "Sandbox runtime for AI coding agents. Firecracker microVMs, a single Go binary, snapshot/fork as first-class primitives.",
    "url": "https://cruciblehq.dev/docs",
    "theme": {
      "accent": {
        "light": "#C0400A",
        "dark": "#FF6A1F"
      },
      "accentHover": {
        "light": "#9C3308",
        "dark": "#FF8442"
      }
    },
    "favicon": "/brand/favicon.svg",
    "logo": {
      "light": "/brand/logo-light.svg",
      "dark": "/brand/logo-dark.svg"
    },
    "homeUrl": "https://cruciblehq.dev"
  },
  "content": {
    "root": "docs",
    "home": "../README.md"
  },
  "assets": [
    {
      "from": "../demo",
      "to": "demo"
    },
    {
      "from": "../brand",
      "to": "brand"
    }
  ],
  "links": {
    "repo": "https://github.com/gnana997/crucible",
    "branch": "main"
  },
  "apiReference": {
    "spec": "openapi.json",
    "label": "API Reference",
    "layout": "pages"
  },
  "security": {
    "csp": {
      "imgSrc": [
        "https://img.shields.io"
      ]
    }
  },
  "tabs": [
    {
      "tab": "Guides",
      "pages": [
        "README",
        {
          "group": "CLI",
          "pages": [
            "cli",
            "cli/run",
            "cli/lifecycle",
            "cli/sandboxes",
            "cli/snapshots",
            "cli/apps",
            "cli/daemon"
          ]
        },
        "apps",
        "tui",
        "profiles",
        "policy",
        "network",
        {
          "group": "Reference",
          "pages": [
            "api",
            "api/create-sandbox",
            "api/exec",
            "api/files",
            "api/fork",
            "mcp",
            "architecture",
            "concepts/network-model",
            "benchmarks"
          ]
        },
        {
          "group": "Project",
          "pages": [
            "vision",
            "roadmap"
          ]
        }
      ]
    },
    {
      "tab": "SDKs",
      "pages": [
        "sdks/overview",
        "sdks/go",
        "sdks/typescript",
        "sdks/python",
        "wire"
      ]
    },
    {
      "tab": "Changelog",
      "pages": [
        "changelog"
      ]
    }
  ],
  "ai": {
    "chat": {
      "provider": "gateway",
      "model": "openai/gpt-4o-mini"
    },
    "embedding": {
      "provider": "gateway",
      "model": "openai/text-embedding-3-small"
    },
    "askAi": {
      "enabled": true
    },
    "limits": {
      "ask": {
        "limit": 30,
        "windowMs": 60000
      }
    }
  },
  "mcp": {
    "path": "/mcp-server"
  }
}
