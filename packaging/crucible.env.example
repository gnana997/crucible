# crucible daemon configuration.
#
# CRUCIBLE_FLAGS is passed verbatim to `crucible daemon` (systemd splits
# it on whitespace, so keep it on a single line). Edit the paths for your
# host, then apply with:
#
#   sudo systemctl restart crucible
#
# Run `crucible daemon --help` for the full flag list. Common flags:
#   --firecracker-bin PATH   firecracker binary            (required)
#   --kernel PATH            uncompressed vmlinux           (required)
#   --rootfs PATH            default guest rootfs image     (required)
#   --jailer-bin PATH        enables snapshot/fork + jailer isolation
#   --rootfs-dir DIR         directory of <profile>.ext4 images
#   --work-base DIR          per-sandbox workdirs + durable registry (keep this
#                            OFF /tmp for a service — the registry must survive reboot)
#   --listen HOST:PORT       API listen address (default 127.0.0.1:7878)
#   --network-egress-iface   host NIC for sandbox egress (enables networking)
#   --token-file PATH        bearer-key store (default /var/lib/crucible/tokens.json);
#                            add keys with `crucible daemon token add`. Auth turns on
#                            once a key exists. To expose a non-loopback --listen you
#                            MUST set keys and --tls-cert/--tls-key.
#   --tls-cert / --tls-key   PEM cert+key; required to bind a non-loopback address

CRUCIBLE_FLAGS="--firecracker-bin /usr/local/bin/firecracker --kernel /var/lib/crucible/vmlinux --rootfs /var/lib/crucible/rootfs.ext4 --jailer-bin /usr/local/bin/jailer --rootfs-dir /var/lib/crucible/profiles --work-base /var/lib/crucible/run --listen 127.0.0.1:7878 --log-format json"
