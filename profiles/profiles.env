# crucible rootfs profiles — profile name -> base OCI image.
#
# Each profile is built into a native ext4 rootfs by injecting systemd +
# the crucible-agent into the official language base image (see
# scripts/build-profile.sh and profiles/Dockerfile). Because the base is
# the real upstream image, the toolchain lives where the language expects
# it — no bolted-on tarballs, no PATH surprises for agent code.
#
# Format: <profile>  <base-image>
# Build : make profile PROFILE=<name>     (output: assets/profiles/<name>.ext4)
# Serve : crucible daemon --rootfs-dir assets/profiles ...
#
# To add a version, add a line here — the profile name is whatever the
# create request selects via its `profile` field. Pin exact base tags so
# builds are reproducible.

base           debian:12-slim

python-3.12    python:3.12-slim-bookworm
python-3.13    python:3.13-slim-bookworm

node-20        node:20-bookworm-slim
node-22        node:22-bookworm-slim
node-24        node:24-bookworm-slim

go-1.23        golang:1.23-bookworm
go-1.24        golang:1.24-bookworm
